# Fetch Coder Development Environment
# Copy to .env and fill in your values

# ============================================================================
# CORE SETTINGS
# ============================================================================
IS_DEV=true
ENVIRONMENT=local

# ============================================================================
# TELEMETRY (Optional)
# ============================================================================
# TELEMETRY_API_KEY=your-api-key
# ERROR_TRACKING_API_KEY=your-api-key

# ============================================================================
# STORAGE (Optional - S3 or R2)
# ============================================================================
# STORAGE_ADAPTER=s3
# STORAGE_BUCKET=fetch-coder
# STORAGE_ACCESS_KEY_ID=key
# STORAGE_SECRET_ACCESS_KEY=secret
# STORAGE_REGION=us-east-1

# ============================================================================
# TERMINAL & AUTO-START
# ============================================================================
AUTO_TERMINAL_ENABLED=true
TERMINAL_AUTO_SCROLL=true
TERMINAL_WRAP_TEXT=true
