{
	"name": "fetch-coder",
	"displayName": "Fetch Coder",
	"description": "Fetch Coder POC: autonomous coding agent for VS Code using ASI:One (OpenAI-compatible API). Not for upstream Asi.",
	"version": "0.2.1",
	"icon": "assets/icons/icon.png",
	"workspaces": [
		"."
	],
	"engines": {
		"vscode": "^1.84.0"
	},
	"author": {
		"name": "gautammanak2"
	},
	"license": "Apache-2.0",
	"publisher": "gautammanak2",
	"repository": {
		"type": "git",
		"url": "https://github.com/gautammanak1/asi1-vs-code.git"
	},
	"homepage": "https://github.com/gautammanak1/asi1-vs-code#readme",
	"bugs": {
		"url": "https://github.com/gautammanak1/asi1-vs-code/issues"
	},
	"categories": [
		"AI",
		"Chat",
		"Programming Languages",
		"Education",
		"Snippets",
		"Testing"
	],
	"keywords": [
		"fetch",
		"asi1",
		"asi-one",
		"mcp",
		"coding",
		"agent",
		"autonomous",
		"ai",
		"openai-compatible"
	],
	"activationEvents": [
		"onLanguage",
		"onUri",
		"onStartupFinished",
		"workspaceContains:evals.env"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"icons": {
			"Asi-icon": {
				"description": "Asi",
				"default": {
					"fontPath": "assets/icons/Asi-bot.woff",
					"fontCharacter": "\\e900"
				}
			}
		},
		"walkthroughs": [
			{
				"id": "FetchCoderWalkthrough",
				"title": "Meet Fetch Coder, your ASI:One coding partner",
				"description": "Fetch Coder helps you build with ASI:One. Here are five ways to put it to work:",
				"steps": [
					{
						"id": "welcome",
						"title": "Start with a Goal, Not Just a Prompt",
						"description": "Tell Fetch Coder what you want to achieve. It plans, asks, and then codes with you.",
						"media": {
							"markdown": "walkthrough/step1.md"
						}
					},
					{
						"id": "learn",
						"title": "Let Fetch Coder Learn Your Codebase",
						"description": "Point it at your project. It builds understanding to make smart, context-aware changes.",
						"media": {
							"markdown": "walkthrough/step2.md"
						}
					},
					{
						"id": "advanced-features",
						"title": "Powered by ASI:One",
						"description": "This extension uses the ASI:One API (OpenAI-compatible) for chat completions.",
						"media": {
							"markdown": "walkthrough/step3.md"
						}
					},
					{
						"id": "mcp",
						"title": "Extend with Powerful Tools (MCP)",
						"description": "Connect to databases, APIs, or discover new capabilities in the MCP Marketplace.",
						"media": {
							"markdown": "walkthrough/step4.md"
						}
					},
					{
						"id": "getting-started",
						"title": "You're Always in Control",
						"description": "Review plans and diffs. Approve changes before they happen.",
						"media": {
							"markdown": "walkthrough/step5.md"
						},
						"content": {
							"path": "walkthrough/step5.md"
						}
					}
				]
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "fetch-coder-ActivityBar",
					"title": "Fetch Coder",
					"icon": "assets/icons/icon.png"
				}
			]
		},
		"views": {
			"fetch-coder-ActivityBar": [
				{
					"type": "webview",
					"id": "fetch-coder.SidebarProvider",
					"name": "",
					"icon": "assets/icons/icon.png"
				}
			]
		},
		"commands": [
			{
				"command": "Asi.plusButtonClicked",
				"title": "New Task",
				"icon": "$(add)"
			},
			{
				"command": "Asi.mcpButtonClicked",
				"title": "MCP Servers",
				"icon": "$(server)"
			},
			{
				"command": "Asi.historyButtonClicked",
				"title": "History",
				"icon": "$(history)"
			},
			{
				"command": "Asi.settingsButtonClicked",
				"title": "Settings",
				"icon": "$(settings-gear)"
			},
			{
				"command": "Asi.dev.createTestTasks",
				"title": "Create Test Tasks",
				"category": "Fetch Coder",
				"when": "Asi.isDevMode"
			},
			{
				"command": "Asi.dev.expireMcpOAuthTokens",
				"title": "Expire MCP OAuth Tokens (for testing)",
				"category": "Fetch Coder",
				"when": "Asi.isDevMode"
			},
			{
				"command": "Asi.addToChat",
				"title": "Add to Fetch Coder",
				"category": "Fetch Coder"
			},
			{
				"command": "Asi.addTerminalOutputToChat",
				"title": "Add to Fetch Coder",
				"category": "Fetch Coder"
			},
			{
				"command": "Asi.focusChatInput",
				"title": "Jump to Chat Input",
				"category": "Fetch Coder"
			},
			{
				"command": "Asi.insertApiKey",
				"title": "Fetch Coder: Set ASI:One API Key & Base URL",
				"category": "Fetch Coder"
			},
			{
				"command": "asiAssistant.insertApiKey",
				"title": "ASI: Set API Key",
				"category": "Fetch Coder"
			},
			{
				"command": "Asi.generateGitCommitMessage",
				"title": "Generate Commit Message with Fetch Coder",
				"category": "Fetch Coder",
				"icon": "$(Asi-icon)"
			},
			{
				"command": "Asi.abortGitCommitMessage",
				"title": "Generate Commit Message with Fetch Coder - Stop",
				"category": "Fetch Coder",
				"icon": "$(debug-stop)"
			},
			{
				"command": "Asi.explainCode",
				"title": "Explain with Fetch Coder",
				"category": "Fetch Coder"
			},
			{
				"command": "Asi.improveCode",
				"title": "Improve with Fetch Coder",
				"category": "Fetch Coder"
			},
			{
				"command": "Asi.jupyterGenerateCell",
				"title": "Generate Jupyter Cell with Fetch Coder",
				"category": "Fetch Coder",
				"icon": "$(sparkle)"
			},
			{
				"command": "Asi.jupyterExplainCell",
				"title": "Explain Jupyter Cell with Fetch Coder",
				"category": "Fetch Coder",
				"icon": "$(question)"
			},
			{
				"command": "Asi.jupyterImproveCell",
				"title": "Improve Jupyter Cell with Fetch Coder",
				"category": "Fetch Coder",
				"icon": "$(lightbulb)"
			},
			{
				"command": "Asi.openWalkthrough",
				"title": "Open Walkthrough",
				"category": "Fetch Coder"
			},
			{
				"command": "Asi.reconstructTaskHistory",
				"title": "Reconstruct Task History",
				"category": "Fetch Coder"
			},
			{
				"command": "Asi.reviewComment.reply",
				"title": "Reply",
				"category": "Fetch Coder",
				"enablement": "!commentIsEmpty"
			},
			{
				"command": "Asi.reviewComment.addToChat",
				"title": "Add to Fetch Coder Chat",
				"category": "Fetch Coder",
				"icon": "$(link-external)"
			}
		],
		"keybindings": [
			{
				"command": "editor.action.submitComment",
				"key": "enter",
				"when": "commentEditorFocused && commentController == Asi-ai-review && !commentIsEmpty"
			},
			{
				"command": "Asi.addToChat",
				"key": "cmd+'",
				"mac": "cmd+'",
				"win": "ctrl+'",
				"linux": "ctrl+'",
				"when": "editorHasSelection"
			},
			{
				"command": "Asi.generateGitCommitMessage",
				"when": "config.git.enabled && scmProvider == git"
			},
			{
				"command": "Asi.focusChatInput",
				"key": "cmd+'",
				"mac": "cmd+'",
				"win": "ctrl+'",
				"linux": "ctrl+'",
				"when": "!editorHasSelection"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "Asi.plusButtonClicked",
					"group": "navigation@1",
					"when": "view == fetch-coder.SidebarProvider"
				},
				{
					"command": "Asi.mcpButtonClicked",
					"group": "navigation@2",
					"when": "view == fetch-coder.SidebarProvider"
				},
				{
					"command": "Asi.historyButtonClicked",
					"group": "navigation@3",
					"when": "view == fetch-coder.SidebarProvider"
				},
				{
					"command": "Asi.settingsButtonClicked",
					"group": "navigation@6",
					"when": "view == fetch-coder.SidebarProvider"
				}
			],
			"editor/context": [
				{
					"command": "Asi.addToChat",
					"group": "navigation",
					"when": "editorHasSelection"
				}
			],
			"terminal/context": [
				{
					"command": "Asi.addTerminalOutputToChat",
					"group": "navigation"
				}
			],
			"scm/title": [
				{
					"command": "Asi.generateGitCommitMessage",
					"group": "navigation",
					"when": "config.git.enabled && scmProvider == git && !Asi.isGeneratingCommit"
				},
				{
					"command": "Asi.abortGitCommitMessage",
					"group": "navigation",
					"when": "config.git.enabled && scmProvider == git && Asi.isGeneratingCommit"
				}
			],
			"notebook/toolbar": [
				{
					"command": "Asi.jupyterGenerateCell",
					"group": "navigation/add@1",
					"when": "notebookType == 'jupyter-notebook'"
				}
			],
			"notebook/cell/title": [
				{
					"command": "Asi.jupyterExplainCell",
					"group": "inline@1",
					"when": "notebookType == 'jupyter-notebook'"
				},
				{
					"command": "Asi.jupyterImproveCell",
					"group": "inline@2",
					"when": "notebookType == 'jupyter-notebook'"
				}
			],
			"commandPalette": [
				{
					"command": "Asi.generateGitCommitMessage",
					"when": "config.git.enabled && !Asi.isGeneratingCommit"
				},
				{
					"command": "Asi.abortGitCommitMessage",
					"when": "config.git.enabled && Asi.isGeneratingCommit"
				},
				{
					"command": "Asi.reviewComment.reply",
					"when": "false"
				}
			],
			"comments/commentThread/context": [
				{
					"command": "Asi.reviewComment.reply",
					"group": "inline",
					"when": "commentController == Asi-ai-review"
				}
			],
			"comments/commentThread/title": [
				{
					"command": "Asi.reviewComment.addToChat",
					"group": "inline",
					"when": "commentController == Asi-ai-review"
				}
			]
		},
		"configuration": {
			"title": "Fetch Coder",
			"properties": {
				"asiAssistant.apiKey": {
					"type": "string",
					"default": "",
					"description": "ASI:One API key (optional if ASI_ONE_API_KEY is set). Applied to Fetch Coder OpenAI-compatible provider on startup.",
					"order": 100
				},
				"asiAssistant.baseUrl": {
					"type": "string",
					"default": "https://api.asi1.ai/v1",
					"description": "OpenAI-compatible API base URL (no /chat/completions suffix).",
					"order": 101
				},
				"asiAssistant.model": {
					"type": "string",
					"default": "asi1",
					"description": "Model id for Plan and Act modes when using ASI:One settings sync.",
					"order": 102
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run package",
		"compile": "npm run check-types && npm run lint && node esbuild.mjs",
		"compile-standalone": "npm run check-types && npm run lint && node esbuild.mjs --standalone",
		"compile-standalone-npm": "npm run protos && npm run check-types && npm run lint && node esbuild.mjs --standalone",
		"test:install": "bash scripts/test-install.sh",
		"postcompile-standalone": "node scripts/package-standalone.mjs",
		"postcompile-standalone-npm": "node scripts/package-npm.mjs",
		"dev": "npm run protos && npm run watch",
		"watch": "npx npm-run-all -p watch:*",
		"watch:esbuild": "node esbuild.mjs --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"package": "npm run check-types && npm run build:webview && npm run lint && node esbuild.mjs --production",
		"protos": "node scripts/build-proto.mjs",
		"protos-python": "node scripts/build-python-proto.mjs",
		"download-ripgrep": "node scripts/download-ripgrep.mjs",
		"postprotos": "biome format src/shared/proto src/core/controller src/hosts/ webview-ui/src/services src/generated --write --no-errors-on-unmatched",
		"clean:build": "rimraf dist dist-standalone webview-ui/build src/generated out/",
		"clean:deps": "rimraf node_modules webview-ui/node_modules",
		"clean:all": "npm run clean:build && npm run clean:deps",
		"compile-tests": "node ./scripts/build-tests.js",
		"watch-tests": "tsc -p . -w --outDir out",
		"check-types": "npm run protos && npx tsc --noEmit && cd webview-ui && npx tsc --noEmit",
		"lint": "biome lint --no-errors-on-unmatched --files-ignore-unknown=true --diagnostic-level=error && npm run lint:proto",
		"lint:proto": "bash ./scripts/proto-lint.sh",
		"buf:lint": "buf lint",
		"buf:format": "buf format -w",
		"format": "biome format --changed --no-errors-on-unmatched --files-ignore-unknown=true --diagnostic-level=error",
		"format:fix": "biome check --changed --no-errors-on-unmatched --files-ignore-unknown=true --write",
		"fix:all": "biome check --no-errors-on-unmatched --files-ignore-unknown=true --write --diagnostic-level=error --unsafe",
		"ci:check-all": "npx npm-run-all -p check-types lint format",
		"ci:build": "npm run protos && npm run build:webview && node esbuild.mjs && npm run compile-tests",
		"pretest": "npm run compile && npm run compile-tests && npm run compile-standalone && npm run lint",
		"test": "npx npm-run-all test:unit test:integration",
		"test:integration": "vscode-test",
		"test:unit": "cross-env TS_NODE_PROJECT=./tsconfig.unit-test.json mocha",
		"test:coverage": "vscode-test --coverage",
		"test:sca-server": "npx tsx watch scripts/test-standalone-core-api-server.ts",
		"test:tp-orchestrator": "npx tsx scripts/testing-platform-orchestrator.ts",
		"e2e": "playwright test -c playwright.config.ts",
		"test:e2e:build": "vsce package --allow-package-secrets sendgrid --out dist/e2e.vsix",
		"test:e2e": "playwright install && npm run test:e2e:build && node src/test/e2e/utils/build.mjs && playwright test",
		"test:e2e:optimal": "npm run test:e2e:build && node src/test/e2e/utils/build.mjs && playwright test",
		
		"test:e2e:ui": "npx tsx scripts/interactive-playwright.ts",
		"install:all": "npm install && cd webview-ui && npm install",
		"dev:webview": "cd webview-ui && npm run dev",
		"build:webview": "cd webview-ui && npm run build",
		"test:webview": "cd webview-ui && npm run test",
		"publish:marketplace": "vsce publish --allow-package-secrets sendgrid && ovsx publish",
		"publish:marketplace:prerelease": "vsce publish --allow-package-secrets sendgrid --pre-release && ovsx publish --pre-release",
		"publish:marketplace:nightly": "node ./scripts/publish-nightly.mjs",
		"prepare": "npx husky",
		"report-issue": "node scripts/report-issue.js",
		"storybook": "cd webview-ui && npm run storybook",
		"eval:smoke:run": "npx tsx evals/smoke-tests/run-smoke-tests.ts"
	},
	"lint-staged": {
		"src/shared/storage/state-keys.ts": [
			"node scripts/generate-state-proto.mjs",
			"git add proto/asi/state.proto"
		],
		"*": [
			"biome check --write --staged --no-errors-on-unmatched --files-ignore-unknown=true"
		]
	},
