{
	"name": "fetch-coder",
	"displayName": "Fetch Coder for Cursor",
	"description": "Autonomous AI coding agent for Cursor and VS Code, powered by ASI:One — chat, plan/act, run commands, and edit your repo from the sidebar.",
	"version": "0.2.21",
	"icon": "assets/icons/icon.png",
	"galleryBanner": {
		"color": "#0D0D0D",
		"theme": "dark"
	},
	"workspaces": [
		"."
	],
	"engines": {
		"vscode": "^1.115.0"
	},
	"author": {
		"name": "gautammanak2"
	},
	"license": "Apache-2.0",
	"publisher": "gautammanak2",
	"repository": {
		"type": "git",
		"url": "https://github.com/gautammanak1/asi1-vs-code.git"
	},
	"homepage": "https://github.com/gautammanak1/asi1-vs-code#readme",
	"bugs": {
		"url": "https://github.com/gautammanak1/asi1-vs-code/issues"
	},
	"categories": [
		"AI",
		"Chat",
		"Programming Languages",
		"Education",
		"Snippets",
		"Testing"
	],
	"keywords": [
		"fetch",
		"asi1",
		"cursor",
		"asi-one",
		"mcp",
		"coding",
		"agent",
		"autonomous",
		"ai",
		"openai-compatible"
	],
	"activationEvents": [
		"onLanguage",
		"onUri",
		"onStartupFinished",
		"workspaceContains:evals.env",
		"onCommand:Asi.openAiChat",
		"onCommand:Asi.focusChatInput",
		"onCommand:Asi.plusButtonClicked",
		"onCommand:Asi.addToChat",
		"onCommand:Asi.attachFileToChat",
		"onCommand:Asi.insertApiKey"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"walkthroughs": [
			{
				"id": "FetchCoderWalkthrough",
				"title": "Meet Fetch Coder (Cursor & VS Code)",
				"description": "Fetch Coder is your ASI:One coding partner. Here are quick ways to use it in Cursor or VS Code:",
				"steps": [
					{
						"id": "welcome",
						"title": "Start with a Goal, Not Just a Prompt",
						"description": "Tell Fetch Coder what you want to achieve. It plans, asks, and then codes with you.",
						"media": {
							"markdown": "walkthrough/step1.md"
						}
					},
					{
						"id": "learn",
						"title": "Let Fetch Coder Learn Your Codebase",
						"description": "Point it at your project. It builds understanding to make smart, context-aware changes.",
						"media": {
							"markdown": "walkthrough/step2.md"
						}
					},
					{
						"id": "advanced-features",
						"title": "Powered by ASI:One",
						"description": "This extension uses the ASI:One API (OpenAI-compatible) for chat completions.",
						"media": {
							"markdown": "walkthrough/step3.md"
						}
					},
					{
						"id": "mcp",
						"title": "Extend with Powerful Tools (MCP)",
						"description": "Connect to databases, APIs, or discover new capabilities in the MCP Marketplace.",
						"media": {
							"markdown": "walkthrough/step4.md"
						}
					},
					{
						"id": "getting-started",
						"title": "You're Always in Control",
						"description": "Review plans and diffs. Approve changes before they happen.",
						"media": {
							"markdown": "walkthrough/step5.md"
						},
						"content": {
							"path": "walkthrough/step5.md"
						}
					}
				]
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "fetch-coder-ActivityBar",
					"title": "Fetch Coder",
					"icon": "assets/icons/icon.png"
				}
			]
		},
		"views": {
			"fetch-coder-ActivityBar": [
				{
					"type": "webview",
					"id": "fetch-coder.SidebarProvider",
					"name": "Fetch Coder"
				},
				{
					"id": "fetch-coder.ActivityLauncher",
					"name": "Chat"
				}
			]
		},
		"commands": [
			{
				"command": "Asi.plusButtonClicked",
				"title": "New Task",
				"icon": "$(add)"
			},
			{
				"command": "Asi.mcpButtonClicked",
				"title": "MCP Servers",
				"icon": "$(server)"
			},
			{
				"command": "Asi.historyButtonClicked",
				"title": "History",
				"icon": "$(history)"
			},
			{
				"command": "Asi.settingsButtonClicked",
				"title": "Settings",
				"icon": "$(settings-gear)"
			},
			{
				"command": "Asi.dev.createTestTasks",
				"title": "Create Test Tasks",
				"category": "Fetch Coder",
				"when": "Asi.isDevMode"
			},
			{
				"command": "Asi.dev.expireMcpOAuthTokens",
				"title": "Expire MCP OAuth Tokens (for testing)",
				"category": "Fetch Coder",
				"when": "Asi.isDevMode"
			},
			{
				"command": "Asi.addToChat",
				"title": "Add to Fetch Coder",
				"category": "Fetch Coder"
			},
			{
				"command": "Asi.attachFileToChat",
				"title": "Attach File to Fetch Coder Chat",
				"category": "Fetch Coder"
			},
			{
				"command": "Asi.addTerminalOutputToChat",
				"title": "Add to Fetch Coder",
				"category": "Fetch Coder"
			},
			{
				"command": "Asi.focusChatInput",
				"title": "Jump to Chat Input",
				"category": "Fetch Coder"
			},
			{
				"command": "Asi.openAiChat",
				"title": "Open AI Chat",
				"category": "Fetch Coder",
				"icon": "$(comment-discussion)"
			},
			{
				"command": "Asi.insertApiKey",
				"title": "Fetch Coder: Set ASI:One API Key & Base URL",
				"category": "Fetch Coder"
			},
			{
				"command": "asiAssistant.insertApiKey",
				"title": "ASI: Set API Key",
				"category": "Fetch Coder"
			},
			{
				"command": "Asi.generateGitCommitMessage",
				"title": "Generate Commit Message with Fetch Coder",
				"category": "Fetch Coder",
				"icon": "$(sparkle)"
			},
			{
				"command": "Asi.abortGitCommitMessage",
				"title": "Generate Commit Message with Fetch Coder - Stop",
				"category": "Fetch Coder",
				"icon": "$(debug-stop)"
			},
			{
				"command": "Asi.explainCode",
				"title": "Explain with Fetch Coder",
				"category": "Fetch Coder"
			},
			{
				"command": "Asi.fixWithAsi",
				"title": "Fix with Fetch Coder",
				"category": "Fetch Coder"
			},
			{
				"command": "Asi.improveCode",
				"title": "Improve with Fetch Coder",
				"category": "Fetch Coder"
			},
			{
				"command": "Asi.refactorCode",
				"title": "Refactor with Fetch Coder",
				"category": "Fetch Coder"
			},
			{
				"command": "Asi.jupyterGenerateCell",
				"title": "Generate Jupyter Cell with Fetch Coder",
				"category": "Fetch Coder",
				"icon": "$(sparkle)"
			},
			{
				"command": "Asi.jupyterExplainCell",
				"title": "Explain Jupyter Cell with Fetch Coder",
				"category": "Fetch Coder",
				"icon": "$(question)"
			},
			{
				"command": "Asi.jupyterImproveCell",
				"title": "Improve Jupyter Cell with Fetch Coder",
				"category": "Fetch Coder",
				"icon": "$(lightbulb)"
			},
			{
				"command": "Asi.openWalkthrough",
				"title": "Open Walkthrough",
				"category": "Fetch Coder"
			},
			{
				"command": "Asi.reconstructTaskHistory",
				"title": "Reconstruct Task History",
				"category": "Fetch Coder"
			},
			{
				"command": "Asi.openCheckpoints",
				"title": "Browse Checkpoints",
				"category": "Fetch Coder",
				"icon": "$(history)"
			},
			{
				"command": "Asi.saveCheckpoint",
				"title": "Save Checkpoint",
				"category": "Fetch Coder",
				"icon": "$(save-all)"
			},
			{
				"command": "Asi.revertLast",
				"title": "Revert Last Change",
				"category": "Fetch Coder",
				"icon": "$(discard)"
			},
			{
				"command": "Asi.clearCheckpoints",
				"title": "Clear All Checkpoints",
				"category": "Fetch Coder"
			},
			{
				"command": "Asi.reviewComment.reply",
				"title": "Reply",
				"category": "Fetch Coder",
				"enablement": "!commentIsEmpty"
			},
			{
				"command": "Asi.reviewComment.addToChat",
				"title": "Add to Fetch Coder Chat",
				"category": "Fetch Coder",
				"icon": "$(link-external)"
			}
		],
		"keybindings": [
			{
				"command": "editor.action.submitComment",
				"key": "enter",
				"when": "commentEditorFocused && commentController == Asi-ai-review && !commentIsEmpty"
			},
			{
				"command": "Asi.addToChat",
				"key": "cmd+'",
				"mac": "cmd+'",
				"win": "ctrl+'",
				"linux": "ctrl+'",
				"when": "editorHasSelection"
			},
			{
				"command": "Asi.generateGitCommitMessage",
				"when": "config.git.enabled && scmProvider == git"
			},
			{
				"command": "Asi.focusChatInput",
				"key": "cmd+'",
				"mac": "cmd+'",
				"win": "ctrl+'",
				"linux": "ctrl+'",
				"when": "!editorHasSelection"
			},
			{
				"command": "Asi.focusChatInput",
				"key": "cmd+shift+a",
				"mac": "cmd+shift+a",
				"win": "ctrl+shift+a",
				"linux": "ctrl+shift+a",
				"when": "!editorHasSelection"
			},
			{
				"command": "Asi.revertLast",
				"key": "cmd+shift+z",
				"mac": "cmd+shift+z",
				"win": "ctrl+shift+z",
				"linux": "ctrl+shift+z"
			}
		],
		"menus": {
			"editor/context": [
				{
					"command": "Asi.addToChat",
					"group": "navigation",
					"when": "editorHasSelection"
				}
			],
			"terminal/context": [
				{
					"command": "Asi.addTerminalOutputToChat",
					"group": "navigation"
				}
			],
			"scm/title": [
				{
					"command": "Asi.generateGitCommitMessage",
					"group": "navigation",
					"when": "config.git.enabled && scmProvider == git && !Asi.isGeneratingCommit"
				},
				{
					"command": "Asi.abortGitCommitMessage",
					"group": "navigation",
					"when": "config.git.enabled && scmProvider == git && Asi.isGeneratingCommit"
				}
			],
			"notebook/toolbar": [
				{
					"command": "Asi.jupyterGenerateCell",
					"group": "navigation/add@1",
					"when": "notebookType == 'jupyter-notebook'"
				}
			],
			"notebook/cell/title": [
				{
					"command": "Asi.jupyterExplainCell",
					"group": "inline@1",
					"when": "notebookType == 'jupyter-notebook'"
				},
				{
					"command": "Asi.jupyterImproveCell",
					"group": "inline@2",
					"when": "notebookType == 'jupyter-notebook'"
				}
			],
			"commandPalette": [
				{
					"command": "Asi.generateGitCommitMessage",
					"when": "config.git.enabled && !Asi.isGeneratingCommit"
				},
				{
					"command": "Asi.abortGitCommitMessage",
					"when": "config.git.enabled && Asi.isGeneratingCommit"
				},
				{
					"command": "Asi.reviewComment.reply",
					"when": "false"
				}
			],
			"comments/commentThread/context": [
				{
					"command": "Asi.reviewComment.reply",
					"group": "inline",
					"when": "commentController == Asi-ai-review"
				}
			],
			"comments/commentThread/title": [
				{
					"command": "Asi.reviewComment.addToChat",
					"group": "inline",
					"when": "commentController == Asi-ai-review"
				}
			]
		},
		"configuration": {
			"title": "Fetch Coder for Cursor",
			"properties": {
				"asiAssistant.apiKey": {
					"type": "string",
					"default": "",
					"description": "ASI:One API key (optional if ASI_ONE_API_KEY is set). Applied to Fetch Coder OpenAI-compatible provider on startup.",
					"order": 100
				},
				"asiAssistant.baseUrl": {
					"type": "string",
					"default": "https://api.asi1.ai/v1",
					"description": "OpenAI-compatible API base URL (no /chat/completions suffix).",
					"order": 101
				},
				"asiAssistant.model": {
					"type": "string",
					"default": "asi1",
					"description": "Model id for Plan and Act modes when using ASI:One settings sync.",
					"order": 102
				},
				"fetchCoder.quickActionPrompts": {
					"type": "object",
					"markdownDescription": "Optional overrides for quick-action prompts (Explain, Fix, Improve, Refactor). Placeholders: `{{fileMention}}`, `{{language}}`, `{{selectedText}}`, `{{problemsString}}`.",
					"properties": {
						"explain": {
							"type": "string"
						},
						"fix": {
							"type": "string"
						},
						"improve": {
							"type": "string"
						},
						"improveNotebook": {
							"type": "string"
						},
						"refactor": {
							"type": "string"
						},
						"refactorNotebook": {
							"type": "string"
						}
					},
					"additionalProperties": false,
					"order": 200
				},
				"fetchCoder.quickActionsIncludeFileContext": {
					"type": "boolean",
					"default": false,
					"description": "Append truncated current file content to quick-action prompts when the editor matches the active file.",
					"order": 201
				},
				"fetchCoder.contextMaxFileChars": {
					"type": "number",
					"default": 20000,
					"minimum": 1000,
					"description": "Maximum characters of file text to include when file context is enabled.",
					"order": 202
				},
				"fetchCoder.hostApp": {
					"type": "string",
					"enum": [
						"auto",
						"vscode",
						"cursor"
					],
					"default": "auto",
					"description": "Which editor host to assume for help text: auto uses the running app (e.g. Cursor vs Visual Studio Code). Override only if detection is wrong.",
					"order": 197
				},
				"fetchCoder.brandTheme": {
					"type": "string",
					"enum": [
						"host",
						"cursor-accent"
					],
					"default": "cursor-accent",
					"description": "Sidebar UI accents: 'host' uses classic ASI blue/lime; 'cursor-accent' uses Cursor-style blue/cyan (editor chrome still follows your theme).",
					"order": 199
				},
				"fetchCoder.extraSystemPrompt": {
					"type": "string",
					"default": "",
					"editPresentation": "multiline",
					"maxLength": 8000,
					"description": "Optional text prepended to the model system prompt on every request (in addition to built-in rules).",
					"order": 198
				},
				"fetchCoder.auth0.enabled": {
					"type": "boolean",
					"default": false,
					"description": "Use Auth0 for account sign-in (profile/email). LLM calls still use your API keys / ASI:One settings — not Auth0.",
					"order": 203
				},
				"fetchCoder.auth0.domain": {
					"type": "string",
					"default": "",
					"description": "Auth0 tenant domain (e.g. dev-xxx.us.auth0.com). In Auth0: Application → Native, add the exact redirect URI from the extension (vscode:// or cursor:// … /auth).",
					"order": 204
				},
				"fetchCoder.auth0.clientId": {
					"type": "string",
					"default": "",
					"description": "Auth0 Native application Client ID.",
					"order": 205
				},
				"fetchCoder.auth0.audience": {
					"type": "string",
					"default": "",
					"description": "Optional Auth0 API audience if you use an API identifier for tokens.",
					"order": 206
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run package",
		"compile": "npm run check-types && node esbuild.mjs",
		"compile-standalone": "npm run check-types && node esbuild.mjs --standalone",
		"compile-standalone-npm": "npm run protos && npm run check-types && node esbuild.mjs --standalone",
		"test:install": "bash scripts/test-install.sh",
		"postcompile-standalone": "node scripts/package-standalone.mjs",
		"postcompile-standalone-npm": "node scripts/package-npm.mjs",
		"dev": "npm run protos && npm run watch",
		"watch": "npx npm-run-all -p watch:*",
		"watch:esbuild": "node esbuild.mjs --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"package": "npm run check-types && npm run build:webview && node esbuild.mjs --production",
		"protos": "node scripts/build-proto.mjs",
		"generate:fetchai-knowledge": "node scripts/build-fetchai-knowledge.mjs",
		"protos-python": "node scripts/build-python-proto.mjs",
		"download-ripgrep": "node scripts/download-ripgrep.mjs",
		"postprotos": "biome format src/shared/proto src/core/controller src/hosts/ webview-ui/src/services src/generated --write --no-errors-on-unmatched",
		"clean:build": "rimraf dist dist-standalone webview-ui/build src/generated out/",
		"clean:deps": "rimraf node_modules webview-ui/node_modules",
		"clean:all": "npm run clean:build && npm run clean:deps",
		"compile-tests": "node ./scripts/build-tests.js",
		"watch-tests": "tsc -p . -w --outDir out",
		"check-types": "npm run protos && npx tsc --noEmit && cd webview-ui && npx tsc --noEmit",
		"lint": "biome lint --changed --no-errors-on-unmatched --files-ignore-unknown=true --diagnostic-level=error && npm run lint:proto",
		"lint:proto": "bash ./scripts/proto-lint.sh",
		"buf:lint": "buf lint proto",
		"buf:format": "buf format -w proto",
		"format": "biome format --changed --no-errors-on-unmatched --files-ignore-unknown=true --diagnostic-level=error",
		"format:fix": "biome check --changed --no-errors-on-unmatched --files-ignore-unknown=true --write",
		"fix:all": "biome check --no-errors-on-unmatched --files-ignore-unknown=true --write --diagnostic-level=error --unsafe",
		"ci:check-all": "npx npm-run-all -p check-types lint format",
		"ci:build": "npm run protos && npm run build:webview && node esbuild.mjs && npm run compile-tests",
		"pretest": "npm run compile && npm run compile-tests && npm run compile-standalone",
		"test": "npx npm-run-all test:unit test:integration",
		"test:integration": "vscode-test",
		"test:unit": "cross-env TS_NODE_PROJECT=./tsconfig.unit-test.json TS_NODE_TRANSPILE_ONLY=1 mocha",
		"test:unit:services": "cross-env TS_NODE_PROJECT=./tsconfig.unit-test.json TS_NODE_TRANSPILE_ONLY=1 mocha \"src/test/services/**/*.test.ts\"",
		"test:unit:all": "cross-env TS_NODE_PROJECT=./tsconfig.unit-test.json TS_NODE_TRANSPILE_ONLY=1 mocha \"src/**/__tests__/**/*.ts\" \"src/test/services/**/*.test.ts\"",
		"test:coverage": "vscode-test --coverage",
		"test:sca-server": "npx tsx watch scripts/test-standalone-core-api-server.ts",
		"test:tp-orchestrator": "npx tsx scripts/testing-platform-orchestrator.ts",
		"e2e": "playwright test -c playwright.config.ts",
		"test:e2e:build": "vsce package --allow-package-secrets sendgrid --out dist/e2e.vsix",
		"test:e2e": "playwright install && npm run test:e2e:build && node src/test/e2e/utils/build.mjs && playwright test",
		"test:e2e:optimal": "npm run test:e2e:build && node src/test/e2e/utils/build.mjs && playwright test",
		"test:e2e:ui": "npx tsx scripts/interactive-playwright.ts",
		"install:all": "npm install && cd webview-ui && npm install",
		"dev:webview": "cd webview-ui && npm run dev",
		"build:webview": "cd webview-ui && npm run build",
		"test:webview": "cd webview-ui && npm run test",
		"publish:marketplace": "vsce publish --allow-package-secrets sendgrid && ovsx publish",
		"publish:marketplace:prerelease": "vsce publish --allow-package-secrets sendgrid --pre-release && ovsx publish --pre-release",
		"publish:marketplace:nightly": "node ./scripts/publish-nightly.mjs",
		"postinstall": "patch-package",
		"prepare": "npx husky",
		"report-issue": "node scripts/report-issue.js",
		"storybook": "cd webview-ui && npm run storybook",
		"eval:smoke:run": "npx tsx evals/smoke-tests/run-smoke-tests.ts"
	},
	"lint-staged": {
		"src/shared/storage/state-keys.ts": [
			"node scripts/generate-state-proto.mjs",
			"git add proto/asi/state.proto"
		],
		"*": [
			"biome check --write --staged --no-errors-on-unmatched --files-ignore-unknown=true"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.14",
		"@bufbuild/buf": "^1.54.0",
		"@microsoft/tui-test": "0.0.1",
		"@types/better-sqlite3": "^7.6.13",
		"@types/chai": "^5.0.1",
		"@types/clone-deep": "^4.0.4",
		"@types/diff": "^5.2.1",
		"@types/get-folder-size": "^3.0.4",
		"@types/js-yaml": "^4.0.9",
		"@types/mocha": "^10.0.7",
		"@types/node": "20.x",
		"@types/pdf-parse": "^1.1.4",
		"@types/picomatch": "^4.0.2",
		"@types/proxyquire": "^1.3.31",
		"@types/shell-quote": "^1.7.5",
		"@types/should": "^11.2.0",
		"@types/sinon": "^21.0.0",
		"@types/turndown": "^5.0.5",
		"@types/vscode": "^1.115.0",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/test-electron": "^2.5.2",
		"@vscode/vsce": "^3.6.0",
		"c8": "^10.1.3",
		"chai": "^4.3.10",
		"chalk": "5.6.2",
		"cross-env": "^10.1.0",
		"dotenv": "^17.2.3",
		"esbuild": "^0.25.0",
