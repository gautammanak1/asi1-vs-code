{
  "name": "fetch-coder",
  "displayName": "Fetch Coder",
  "description": "AI coding assistant for VS Code — chat, inline completions, code actions, inline editing, and terminal help powered by ASI1.",
  "icon": "resources/icon.png",
  "version": "0.1.9",
  "publisher": "gautammanak2",
  "license": "MIT",
  "author": "Gautam Manak",
  "homepage": "https://github.com/gautammanak1/asi1-vs-code#readme",
  "bugs": {
    "url": "https://github.com/gautammanak1/asi1-vs-code/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gautammanak1/asi1-vs-code.git"
  },
  "keywords": [
    "asi1",
    "asi",
    "ai",
    "chat",
    "assistant",
    "copilot",
    "fetch",
    "code-completion",
    "inline-chat",
    "code-actions"
  ],
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Machine Learning",
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "asiAssistant.coder",
        "fullName": "Fetch Coder",
        "name": "coder",
        "description": "AI coding assistant powered by ASI1 — explain, fix, generate tests, review, and more",
        "isSticky": true,
        "commands": [
          {
            "name": "explain",
            "description": "Explain the selected code or concept"
          },
          {
            "name": "fix",
            "description": "Fix issues in the selected code"
          },
          {
            "name": "tests",
            "description": "Generate unit tests for the selected code"
          },
          {
            "name": "doc",
            "description": "Generate documentation for the selected code"
          },
          {
            "name": "review",
            "description": "Review the selected code for improvements"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "asiAssistant.openChat",
        "title": "ASI: Open Assistant Chat",
        "category": "Fetch Coder"
      },
      {
        "command": "asiAssistant.askAboutSelection",
        "title": "ASI: Ask About Selection",
        "category": "Fetch Coder"
      },
      {
        "command": "asiAssistant.insertApiKey",
        "title": "ASI: Set API Key",
        "category": "Fetch Coder"
      },
      {
        "command": "asiAssistant.installFromVsix",
        "title": "ASI: Install Extension from .vsix",
        "category": "Fetch Coder"
      },
      {
        "command": "asiAssistant.openChatPanel",
        "title": "Fetch Coder: Open Chat Panel (Right Side)",
        "category": "Fetch Coder",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "asiAssistant.explainSelection",
        "title": "Fetch Coder: Explain This",
        "category": "Fetch Coder",
        "icon": "$(lightbulb)"
      },
      {
        "command": "asiAssistant.fixSelection",
        "title": "Fetch Coder: Fix This",
        "category": "Fetch Coder",
        "icon": "$(wrench)"
      },
      {
        "command": "asiAssistant.generateTests",
        "title": "Fetch Coder: Generate Tests",
        "category": "Fetch Coder",
        "icon": "$(beaker)"
      },
      {
        "command": "asiAssistant.addDocumentation",
        "title": "Fetch Coder: Add Documentation",
        "category": "Fetch Coder",
        "icon": "$(book)"
      },
      {
        "command": "asiAssistant.reviewCode",
        "title": "Fetch Coder: Review Code",
        "category": "Fetch Coder",
        "icon": "$(eye)"
      },
      {
        "command": "asiAssistant.inlineEdit",
        "title": "Fetch Coder: Inline Edit",
        "category": "Fetch Coder",
        "icon": "$(edit)"
      },
      {
        "command": "asiAssistant.terminal.explain",
        "title": "Fetch Coder: Explain Terminal",
        "category": "Fetch Coder"
      },
      {
        "command": "asiAssistant.terminal.fix",
        "title": "Fetch Coder: Fix Terminal Error",
        "category": "Fetch Coder"
      },
      {
        "command": "asiAssistant.toggleInlineCompletion",
        "title": "Fetch Coder: Toggle Inline Completions",
        "category": "Fetch Coder"
      },
      {
        "command": "asiAssistant.showRequestLog",
        "title": "Fetch Coder: Show Request Log",
        "category": "Fetch Coder",
        "icon": "$(list-unordered)"
      },
      {
        "command": "asiAssistant.clearRequestLog",
        "title": "Fetch Coder: Clear Request Log",
        "category": "Fetch Coder"
      },
      {
        "command": "asiAssistant.previewMultiFileEdit",
        "title": "Fetch Coder: Preview Multi-File Edit",
        "category": "Fetch Coder"
      },
      {
        "command": "asiAssistant.applyMultiFileEdit",
        "title": "Fetch Coder: Apply Pending Edits",
        "category": "Fetch Coder"
      },
      {
        "command": "asiAssistant.discardMultiFileEdit",
        "title": "Fetch Coder: Discard Pending Edits",
        "category": "Fetch Coder"
      },
      {
        "command": "asiAssistant.previewWorkspaceEdit",
        "title": "Fetch Coder: Preview Workspace Edit",
        "category": "Fetch Coder"
      },
      {
        "command": "asiAssistant.applyWorkspaceEdit",
        "title": "Fetch Coder: Apply Workspace Edit",
        "category": "Fetch Coder"
      },
      {
        "command": "asiAssistant.rejectWorkspaceEdit",
        "title": "Fetch Coder: Reject Workspace Edit",
        "category": "Fetch Coder"
      },
      {
        "command": "asiAssistant.revertLastChange",
        "title": "Fetch Coder: Revert Last Change",
        "category": "Fetch Coder",
        "icon": "$(discard)"
      },
      {
        "command": "asiAssistant.revertFileChange",
        "title": "Fetch Coder: Revert File Change",
        "category": "Fetch Coder"
      },
      {
        "command": "asiAssistant.revertAllChanges",
        "title": "Fetch Coder: Revert All Changes",
        "category": "Fetch Coder",
        "icon": "$(history)"
      },
      {
        "command": "asiAssistant.showWorkspaceChanges",
        "title": "Fetch Coder: Show Workspace Changes",
        "category": "Fetch Coder",
        "icon": "$(git-compare)"
      },
      {
        "command": "asiAssistant.deleteFile",
        "title": "Fetch Coder: Delete File",
        "category": "Fetch Coder"
      },
      {
        "command": "asiAssistant.renameFile",
        "title": "Fetch Coder: Rename File",
        "category": "Fetch Coder"
      },
      {
        "command": "asiAssistant.scanWorkspace",
        "title": "Fetch Coder: Scan Workspace Files",
        "category": "Fetch Coder",
        "icon": "$(search)"
      },
      {
        "command": "asiAssistant.composerMode",
        "title": "Fetch Coder: Composer Mode",
        "category": "Fetch Coder",
        "icon": "$(wand)"
      },
      {
        "command": "asiAssistant.showAuditLog",
        "title": "Fetch Coder: Show Audit Log",
        "category": "Fetch Coder",
        "icon": "$(output)"
      },
      {
        "command": "asiAssistant.clearAuditLog",
        "title": "Fetch Coder: Clear Audit Log",
        "category": "Fetch Coder"
      },
      {
        "command": "asiAssistant.exportChat",
        "title": "Fetch Coder: Export Chat",
        "category": "Fetch Coder",
        "icon": "$(export)"
      },
      {
        "command": "asiAssistant.aiCommit",
        "title": "Fetch Coder: AI Commit Message",
        "category": "Fetch Coder",
        "icon": "$(git-commit)"
      },
      {
        "command": "asiAssistant.aiPullRequest",
        "title": "Fetch Coder: Generate PR Description",
        "category": "Fetch Coder",
        "icon": "$(git-pull-request)"
      },
      {
        "command": "asiAssistant.scaffold",
        "title": "Fetch Coder: Project Scaffold",
        "category": "Fetch Coder",
        "icon": "$(folder-library)"
      },
      {
        "command": "asiAssistant.editCustomInstructions",
        "title": "Fetch Coder: Edit Custom Instructions",
        "category": "Fetch Coder",
        "icon": "$(note)"
      },
      {
        "command": "asiAssistant.addCustomInstruction",
        "title": "Fetch Coder: Add Custom Instruction",
        "category": "Fetch Coder"
      },
      {
        "command": "asiAssistant.clearCustomInstructions",
        "title": "Fetch Coder: Clear Custom Instructions",
        "category": "Fetch Coder"
      },
      {
        "command": "asiAssistant.fetchaiAgent",
        "title": "Fetch Coder: Fetch.ai Agent Tools",
        "category": "Fetch Coder",
        "icon": "$(hubot)"
      },
      {
        "command": "asiAssistant.fetchaiDocs",
        "title": "Fetch Coder: Fetch.ai Documentation",
        "category": "Fetch Coder",
        "icon": "$(book)"
      },
      {
        "command": "asiAssistant.fetchaiAgentverse",
        "title": "Fetch Coder: Open Agentverse",
        "category": "Fetch Coder",
        "icon": "$(globe)"
      }
    ],
    "submenus": [
      {
        "id": "asiAssistant.editorSubmenu",
        "label": "Fetch Coder"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "asiAssistant.editorSubmenu",
          "group": "z_fetchCoder"
        }
      ],
      "asiAssistant.editorSubmenu": [
        {
          "command": "asiAssistant.explainSelection",
          "when": "editorHasSelection",
          "group": "1_understand"
        },
        {
          "command": "asiAssistant.fixSelection",
          "when": "editorHasSelection",
          "group": "2_modify"
        },
        {
          "command": "asiAssistant.generateTests",
          "when": "editorHasSelection",
          "group": "2_modify"
        },
        {
          "command": "asiAssistant.addDocumentation",
          "when": "editorHasSelection",
          "group": "2_modify"
        },
        {
          "command": "asiAssistant.reviewCode",
          "when": "editorHasSelection",
          "group": "3_review"
        },
        {
          "command": "asiAssistant.inlineEdit",
          "group": "4_inline"
        },
        {
          "command": "asiAssistant.askAboutSelection",
          "group": "5_other"
        }
      ],
      "terminal/context": [
        {
          "command": "asiAssistant.terminal.explain",
          "group": "z_fetchCoder"
        },
        {
          "command": "asiAssistant.terminal.fix",
          "group": "z_fetchCoder"
        }
      ],
      "commandPalette": [
        {
          "command": "asiAssistant.explainSelection",
          "when": "editorHasSelection"
        },
        {
          "command": "asiAssistant.fixSelection",
          "when": "editorHasSelection"
        },
        {
          "command": "asiAssistant.generateTests",
          "when": "editorHasSelection"
        },
        {
          "command": "asiAssistant.addDocumentation",
          "when": "editorHasSelection"
        },
        {
          "command": "asiAssistant.reviewCode",
          "when": "editorHasSelection"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "asiAssistant",
          "title": "Fetch Coder",
          "icon": "resources/icon.png"
        }
      ]
    },
    "views": {
      "asiAssistant": [
        {
          "type": "webview",
          "id": "asiAssistant.chatView",
          "name": "Chat"
        }
      ]
    },
    "configuration": {
      "title": "Fetch Coder",
      "properties": {
        "asiAssistant.apiKey": {
          "type": "string",
          "default": "",
          "description": "ASI1 API key (optional if ASI_ONE_API_KEY is set in the environment)",
          "order": 1
        },
        "asiAssistant.baseUrl": {
          "type": "string",
          "default": "https://api.asi1.ai/v1/chat/completions",
          "description": "Chat completions endpoint URL",
          "order": 2
        },
        "asiAssistant.model": {
          "type": "string",
          "default": "asi1",
          "description": "Model id",
          "order": 3
        },
        "asiAssistant.imageBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Optional override for image API base (e.g. https://api.asi1.ai/v1). Empty derives from asiAssistant.baseUrl.",
          "order": 31
        },
        "asiAssistant.imageModel": {
          "type": "string",
          "default": "",
          "description": "Model id for image/generate. Empty falls back to asiAssistant.model.",
          "order": 32
        },
        "asiAssistant.imageSize": {
          "type": "string",
          "default": "1024x1024",
          "description": "Default size for image generation (e.g. 1024x1024).",
          "order": 33
        },
        "asiAssistant.systemPrompt": {
          "type": "string",
          "default": "You are a coding assistant in VS Code/Cursor with full workspace access. Use ONLY standard GitHub-flavored markdown with triple-backtick fences and language tags. When the user asks you to edit/fix/change a SPECIFIC part of existing code, show ONLY the changed section (~5-15 lines with context), NOT the entire file. For new files use full code with Save as `path/file.ext`. You can create files, create directories, read files, search the workspace, and run terminal commands (npm, git, mkdir, etc.) directly on the user's system using the available tools. Always prefer using tools to perform actions instead of just showing commands. Tables, lists, and headings are welcome.",
          "description": "System message prepended to every conversation",
          "order": 4
        },
        "asiAssistant.streamResponse": {
          "type": "boolean",
          "default": true,
          "description": "Stream the model reply (SSE). Ignored while built-in tools are enabled (tools use non-streaming rounds).",
          "order": 5
        },
        "asiAssistant.webSearch": {
          "type": "boolean",
          "default": true,
          "description": "Send ASI:One web_search so the model can use live web results.",
          "order": 51
        },
        "asiAssistant.enableTools": {
          "type": "boolean",
          "default": true,
          "description": "Enable client-side tools (read/search workspace files) with ASI:One tool calling.",
          "order": 52
        },
        "asiAssistant.agenticSession": {
          "type": "boolean",
          "default": false,
          "description": "Send x-session-id for Agentverse / agentic flows (ASI:One).",
          "order": 53
        },
        "asiAssistant.sessionId": {
          "type": "string",
          "default": "",
          "description": "Optional fixed x-session-id (overrides auto).",
          "order": 54
        },
        "asiAssistant.maxToolRounds": {
          "type": "number",
          "default": 12,
          "minimum": 1,
          "maximum": 32,
          "description": "Max API rounds when resolving tool calls.",
          "order": 55
        },
        "asiAssistant.autoApplyFiles": {
          "type": "boolean",
          "default": true,
          "description": "Automatically write detected files to the open workspace after each reply.",
          "order": 6
        },
        "asiAssistant.inlineCompletion.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable inline code completions (ghost text). Sends code context to the ASI1 API as you type.",
          "order": 60
        },
        "asiAssistant.inlineCompletion.debounceMs": {
          "type": "number",
          "default": 400,
          "minimum": 100,
          "maximum": 3000,
          "description": "Delay in milliseconds before triggering an inline completion request.",
          "order": 61
        },
        "asiAssistant.bannerTitle": {
          "type": "string",
          "default": "",
          "description": "Optional title next to the banner logo (leave empty to show logo only)",
          "order": 10
        },
        "asiAssistant.bannerSubtitle": {
          "type": "string",
          "default": "Fetch Coder · VS Code & Cursor",
          "description": "Short line under the banner title (leave empty to hide)",
          "order": 11
        },
        "asiAssistant.bannerLogoUrl": {
          "type": "string",
          "default": "",
          "description": "Optional https URL for the banner logo. Empty uses the bundled Fetch Coder logo.",
          "order": 12
        },
        "asiAssistant.linkWebsite": {
          "type": "string",
          "default": "https://fetch.ai",
          "description": "Banner link: Website (https://…)",
          "order": 20
        },
        "asiAssistant.linkDocs": {
          "type": "string",
          "default": "https://docs.fetch.ai",
          "description": "Banner link: Docs",
          "order": 21
        },
        "asiAssistant.linkX": {
          "type": "string",
          "default": "",
          "description": "Banner link: X (Twitter)",
          "order": 22
        },
        "asiAssistant.linkCommunity": {
          "type": "string",
          "default": "",
          "description": "Banner link: Community",
          "order": 23
        },
        "asiAssistant.linkResources": {
          "type": "string",
          "default": "",
          "description": "Banner link: Resources",
          "order": 24
        },
        "asiAssistant.linkSupport": {
          "type": "string",
          "default": "",
          "description": "Banner link: Support",
          "order": 25
        },
        "asiAssistant.linkContact": {
          "type": "string",
          "default": "",
          "description": "Banner link: Contact us",
          "order": 26
        }
      }
    },
    "keybindings": [
      {
        "command": "asiAssistant.openChat",
        "key": "ctrl+shift+;",
        "mac": "cmd+shift+;"
      },
      {
        "command": "asiAssistant.openChatPanel",
        "key": "ctrl+shift+alt+;",
        "mac": "cmd+shift+alt+;"
      },
      {
        "command": "asiAssistant.inlineEdit",
        "key": "ctrl+i",
        "mac": "cmd+i",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --readme-path README.vsix.md"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.91.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "highlight.js": "^11.11.1"
  }
}
